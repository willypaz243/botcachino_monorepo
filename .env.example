# Agent Configuration
AGENT__UNIVERSITY_NAME="Universidad Mayor de San Simon (UMSS)"

# Main model
AGENT__MODEL__PROVIDER=cerebras
AGENT__MODEL__NAME=gpt-oss-120b
AGENT__MODEL__TEMPERATURE=0.3

# Router model
AGENT__ROUTER_MODEL__PROVIDER=groq
AGENT__ROUTER_MODEL__NAME=llama-3.3-70b-versatile
AGENT__ROUTER_MODEL__TEMPERATURE=0.1

AGENT__MAX_SEARCH_RETRIES=5
AGENT__DEFAULT_SEARCH_LIMIT=20
AGENT__MAX_RESPONSE_TOKENS=1024
AGENT__REQUEST_DELAY=0.5

# IA Services Api keys
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NEBIUS_API_KEY=


# Database
DATABASE__URL="postgresql+asyncpg://postgres:postgres@localhost:5432/botcachino"

# API Configuration
API__KEY=<generar-con-openssl-rand-hex-32>
API__ALLOWED_ORIGINS=https://botcachino.scesi.dev
API__HOST=0.0.0.0
API__PORT=8000
API__DEBUG=false
